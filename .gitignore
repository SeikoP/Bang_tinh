# ========================================
# WMS Project .gitignore
# ========================================

# Python bytecode & artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
*.egg-info/
*.egg

# Virtual Environment
.venv/
venv/
ENV/
env/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.kiro/

# Testing
.pytest_cache/
.hypothesis/
.coverage
htmlcov/
coverage.xml
*.cover
.mypy_cache/
.ruff_cache/

# Security — never commit secret keys
.secret_key

# Runtime data
data/logs/*.log
data/logs/*.log.*
data/exports/*
data/backups/*
data/cache/*
!data/logs/.gitkeep
!data/exports/.gitkeep
!data/backups/.gitkeep
!data/cache/.gitkeep

# Database
*.db
*.db-journal
*.db-wal
*.db-shm

# Build output (NOT the build/ config directory)
dist/
Output/
*.spec.bak
*.manifest

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.local
!.env.example

# Logs
logs/
*.log

# Android notifier build artifacts
android_notifier/local.properties
android_notifier/.gradle/
android_notifier/build/
android_notifier/app/build/

# TTS Cache
tts_cache/

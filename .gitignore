# ========================================
# WMS Project .gitignore
# ========================================

# Python bytecode & packaging artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.kiro/

# Testing / quality caches
.pytest_cache/
.hypothesis/
.coverage
htmlcov/
coverage.xml
*.cover
.mypy_cache/
.ruff_cache/

# Security — never commit secret keys
.secret_key
secret_key.txt

# Runtime data
data/logs/*.log
data/logs/*.log.*
data/exports/*
data/backups/*
data/cache/*
!data/logs/.gitkeep
!data/exports/.gitkeep
!data/backups/.gitkeep
!data/cache/.gitkeep

# Databases
*.db
*.db-journal
*.db-wal
*.db-shm

# Build outputs
dist/
Output/
.pyi-build/
*.spec.bak
*.manifest

# Keep build configuration in repo, ignore generated files under build/
build/*
!build/warehouse_app.spec
!build/version_info.txt
!build/installer/
!build/installer/setup.iss

# Logs
logs/
*.log

# Environment files
.env
.env.local
!.env.example

# Android notifier build artifacts
android_notifier/local.properties
android_notifier/.gradle/
android_notifier/build/
android_notifier/app/build/

# TTS cache
tts_cache/

# OS
.DS_Store
Thumbs.db
desktop.ini

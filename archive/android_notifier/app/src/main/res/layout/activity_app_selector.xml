<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/surface">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️ Thần hộ mệnh (App Guardian)"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_title" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chọn các App ngân hàng để tự động đánh thức, chống ngủ đông khi khóa máy."
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/appSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔍 Tìm ứng dụng (ví dụ: vcb, momo...)"
                android:padding="12dp"
                android:background="@drawable/bg_input"
                android:textSize="14sp"
                android:importantForAutofill="no" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="8dp"
        app:cardCornerRadius="0dp"
        android:background="@color/surface">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <EditText
                    android:id="@+id/manualPackageInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Nhập Package Name (nếu ko thấy)"
                    android:textSize="12sp"
                    android:padding="10dp"
                    android:background="@drawable/bg_input" />
                <Button
                    android:id="@+id/addManualBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thêm"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#475569" />
            </LinearLayout>

            <Button
                android:id="@+id/saveAppsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Lưu cấu hình bảo vệ"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:padding="12dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>

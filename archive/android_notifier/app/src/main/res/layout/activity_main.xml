<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════════════════════════════════ -->
        <!-- HERO HEADER with Gradient Background    -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_card"
            android:paddingTop="40dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="20dp">

            <!-- App Title Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💳 Bank Notifier"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:letterSpacing="0.02" />

                <!-- Connection Badge -->
                <TextView
                    android:id="@+id/connectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 Chưa kết nối"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:background="@drawable/bg_status_dot"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>

            <!-- Status Info Row -->
            <LinearLayout
                android:id="@+id/statusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_rounded"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="❌ Chưa cấp quyền"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main" />

                    <TextView
                        android:id="@+id/watchdogStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡️ Watchdog"
                        android:textSize="11sp"
                        android:textColor="@color/primary_dark"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/lastSyncText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kiểm tra cuối: Chưa bao giờ"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Content Area with Padding -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp">

            <!-- ═══════════════════════════════════════ -->
            <!-- STATS ROW - Three compact metrics       -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Stat: Sent -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/accent_container">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/statSent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đã gửi"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stat: Success -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/success_container">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/statSuccess"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/success" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thành công"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stat: Failed -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/error_container">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/statFailed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/error" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lỗi"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- PRIMARY ACTION: Remote Giao Ca          -->
            <!-- ═══════════════════════════════════════ -->
            <Button
                android:id="@+id/remoteInputButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋  Nhập Chốt Ca từ Điện Thoại"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:textAllCaps="false" />

            <!-- ═══════════════════════════════════════ -->
            <!-- CONFIGURATION CARD                      -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚙️  Cấu hình kết nối"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_title"
                        android:layout_marginBottom="14dp" />

                    <EditText
                        android:id="@+id/serverUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="http://192.168.x.x:5005"
                        android:inputType="textUri"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:background="@drawable/bg_input"
                        android:layout_marginBottom="14dp" />

                    <!-- QR + Save buttons side by side -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <Button
                            android:id="@+id/scanQrButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="📷 Quét QR"
                            android:textSize="13sp"
                            android:backgroundTint="@color/btn_dark"
                            android:textColor="@color/white"
                            android:layout_marginEnd="6dp"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/saveButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="💾 Lưu cấu hình"
                            android:textSize="13sp"
                            android:backgroundTint="@color/primary"
                            android:textColor="@color/white"
                            android:layout_marginStart="6dp"
                            android:textAllCaps="false" />
                    </LinearLayout>

                    <!-- Separator -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_light"
                        android:layout_marginBottom="14dp" />

                    <!-- Switches Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tự động chuyển tiếp"
                            android:textSize="14sp"
                            android:textColor="@color/text_main" />
                        <Switch
                            android:id="@+id/enabledSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Chế độ Debug"
                            android:textSize="14sp"
                            android:textColor="@color/text_main" />
                        <Switch
                            android:id="@+id/debugSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!-- TESTING TOOLS CARD                      -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🧪  Kiểm tra kết nối"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_title"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/testButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="🧪 Thử kết nối"
                            android:textSize="13sp"
                            android:backgroundTint="@color/btn_subtle"
                            android:textColor="@color/white"
                            android:layout_marginEnd="6dp"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/testSampleButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="💸 Gửi mẫu"
                            android:textSize="13sp"
                            android:backgroundTint="#10b981"
                            android:textColor="@color/white"
                            android:layout_marginStart="6dp"
                            android:textAllCaps="false" />
                    </LinearLayout>

                    <!-- Test tip -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 Gửi notification giả lập VietinBank (+5tr) để test PC có nhận được không."
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!-- SYSTEM TOOLS CARD                       -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔧  Hỗ trợ hệ thống"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_title"
                        android:layout_marginBottom="14dp" />

                    <!-- System buttons grid: 2 columns -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <Button
                            android:id="@+id/permissionButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="🔓 Cấp quyền"
                            android:textSize="12sp"
                            android:backgroundTint="@color/btn_dark"
                            android:textColor="@color/white"
                            android:layout_marginEnd="6dp"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/batteryButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="🔋 Tắt tối ưu pin"
                            android:textSize="12sp"
                            android:backgroundTint="@color/btn_dark"
                            android:textColor="@color/white"
                            android:layout_marginStart="6dp"
                            android:textAllCaps="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <Button
                            android:id="@+id/appGuardianButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="🛡️ Giám sát App"
                            android:textSize="12sp"
                            android:backgroundTint="@color/primary_dark"
                            android:textColor="@color/white"
                            android:layout_marginEnd="6dp"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/historyButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="📜 Lịch sử"
                            android:textSize="12sp"
                            android:backgroundTint="@color/btn_dark"
                            android:textColor="@color/white"
                            android:layout_marginStart="6dp"
                            android:textAllCaps="false" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/autoStartButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="🚀 Tự khởi chạy (Auto-start)"
                        android:textSize="12sp"
                        android:backgroundTint="@color/btn_dark"
                        android:textColor="@color/white"
                        android:visibility="gone"
                        android:textAllCaps="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!-- TIPS CARD (Collapsible style)           -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/info_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🛡️ Khắc phục App bị ngủ đông"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_info_container"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="① Khóa app: Mở Đa nhiệm → vuốt xuống hoặc nhấn 🔒"
                        android:textSize="12sp"
                        android:textColor="@color/on_info_container"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="② Tắt tối ưu pin cho cả APP NGÂN HÀNG: Vào cài đặt pin → 'Không hạn chế'"
                        android:textSize="12sp"
                        android:textColor="@color/on_info_container"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="③ Cho phép chạy nền: Bật 'Hiển thị trên ứng dụng khác' và 'Tự khởi chạy'"
                        android:textSize="12sp"
                        android:textColor="@color/on_info_container" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!-- EXIT BUTTON (Danger Zone)               -->
            <!-- ═══════════════════════════════════════ -->
            <Button
                android:id="@+id/exitAppButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏹️  Tắt hoàn toàn"
                android:backgroundTint="@color/error"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="14dp"
                android:layout_marginBottom="32dp"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>

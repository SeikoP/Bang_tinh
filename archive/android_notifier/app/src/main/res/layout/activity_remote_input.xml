<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_main">

        <!-- ═══════════════════════════════════════ -->
        <!-- APP BAR with Gradient                   -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_appbar_gradient"
            android:paddingTop="40dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp">

            <!-- Title Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📋 Nhập Chốt Ca"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff" />

                <Button
                    android:id="@+id/btnScratchpad"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="📝 Nháp"
                    android:textSize="11sp"
                    android:padding="0dp"
                    android:paddingHorizontal="14dp"
                    android:backgroundTint="#ffffff"
                    android:textColor="@color/primary_dark"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- Status line -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đang kết nối..."
                android:textSize="13sp"
                android:textColor="#d1fae5" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════ -->
        <!-- LOADING INDICATOR                       -->
        <!-- ═══════════════════════════════════════ -->
        <ProgressBar
            android:id="@+id/loadingProgress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:indeterminateTint="@color/primary"
            android:visibility="gone" />

        <!-- ═══════════════════════════════════════ -->
        <!-- SESSION LIST (RecyclerView)             -->
        <!-- ═══════════════════════════════════════ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sessionRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false" />

        <!-- ═══════════════════════════════════════ -->
        <!-- BOTTOM PANEL: Total + Actions           -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_panel"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:elevation="8dp">

            <!-- Total Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TỔNG TIỀN CA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/totalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0đ"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark" />
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/refreshButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="🔄 Tải lại"
                    android:textSize="13sp"
                    android:backgroundTint="@color/surface_container_high"
                    android:textColor="@color/text_main"
                    android:layout_marginEnd="8dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/saveButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1.5"
                    android:text="✅ Lưu &amp; Cập nhật"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════ -->
    <!-- SCRATCHPAD OVERLAY                      -->
    <!-- ═══════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/scratchpadOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFF9C4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="#FEFCE8">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📝 GIẤY NHÁP TẠM THỜI"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#854d0e" />
                </LinearLayout>

                <com.banknotifier.ScratchpadView
                    android:id="@+id/scratchpadView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnClearScratchpad"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="🧹 Xóa nháp"
                        android:backgroundTint="#f8fafc"
                        android:textColor="#334155"
                        android:layout_marginEnd="12dp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnCloseScratchpad"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="❌ Đóng"
                        android:backgroundTint="@color/btn_dark"
                        android:textColor="#ffffff"
                        android:textAllCaps="false" />
                </LinearLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>
</FrameLayout>

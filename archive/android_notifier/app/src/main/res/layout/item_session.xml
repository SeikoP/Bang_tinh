<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_light"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Row 1: Product Name + Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/productName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sản phẩm"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_title"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/amountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Row 2: Info (Handover/Used) + Stepper (Input) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <!-- Sub-info: Small and clean -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">
                
                <TextView
                    android:id="@+id/handoverText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="G: 0"
                    android:textSize="11sp"
                    android:textColor="@color/on_success_container"
                    android:background="@drawable/bg_badge_handover"
                    android:paddingHorizontal="6dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/usedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D: 0"
                    android:textSize="11sp"
                    android:textColor="@color/on_warning_container"
                    android:background="@drawable/bg_badge_used"
                    android:paddingHorizontal="6dp" />
            </LinearLayout>

            <!-- Compact Stepper -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_rounded"
                android:backgroundTint="@color/surface_variant"
                android:padding="2dp">

                <Button
                    android:id="@+id/minusBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="−"
                    android:textSize="16sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="@color/surface_container_high"
                    android:textColor="@color/text_main"
                    style="@style/Widget.AppCompat.Button.Borderless" />

                <EditText
                    android:id="@+id/closingInput"
                    android:layout_width="50dp"
                    android:layout_height="32dp"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:gravity="center"
                    android:background="@android:color/transparent"
                    android:hint="0"
                    android:textColor="@color/text_title"
                    android:textColorHint="@color/text_hint" />

                <Button
                    android:id="@+id/plusBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textSize="16sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="@color/primary_container"
                    android:textColor="@color/primary_dark"
                    style="@style/Widget.AppCompat.Button.Borderless" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
